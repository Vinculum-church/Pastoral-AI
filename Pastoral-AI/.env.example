# =============================================================================
# SUPABASE (Frontend) - Onde colocar no projeto Pastoral-AI
# =============================================================================
# Crie um arquivo .env na pasta Pastoral-AI (ou use .env.local) e preencha:
# Onde pegar: Supabase → Settings → API
# -----------------------------------------------------------------------------
# Project URL: copie o "Project URL" da seção DATA API
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
# Publishable Key: copie a chave "anon" (pública) em "Project API keys"
# Use só no frontend; nunca coloque a service_role aqui
VITE_SUPABASE_ANON_KEY=sua-anon-publishable-key-aqui

# =============================================================================
# Stripe
# =============================================================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
VITE_STRIPE_PUBLISHABLE_KEY=

# App Configuration
APP_URL=
GEMINI_API_KEY=
